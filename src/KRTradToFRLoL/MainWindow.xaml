<Window x:Class="KRTradToFRLoL.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KRTradToFRLoL — Traducteur de chat LoL coréen" Height="560" Width="640"
        Background="#FF1B1B22" Foreground="White" Closing="OnClosing">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Proxy (mode normal pour les streamers : la clé reste côté serveur) -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Proxy + token :" VerticalAlignment="Center" Width="130"
                       ToolTip="Mode normal. URL https du relais (ex. https://….vercel.app/api/translate) + token fourni par l'organisateur."/>
            <TextBox x:Name="ProxyUrlBox" Width="220" VerticalContentAlignment="Center"/>
            <PasswordBox x:Name="ProxyTokenBox" Width="104" Margin="6,0,0,0" VerticalContentAlignment="Center"/>
            <Button Content="Enregistrer" Margin="8,0,0,0" Padding="10,4" Click="OnSaveProxy"/>
        </StackPanel>

        <!-- Clé API (mode avancé : self-host avec sa propre clé, sans proxy) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="ou clé API (avancé) :" VerticalAlignment="Center" Width="130" Foreground="#FF9090A0"
                       ToolTip="Réservé au self-host/dev : ta propre clé API Anthropic, chiffrée localement (DPAPI). Les streamers n'en ont pas besoin — le proxy suffit."/>
            <PasswordBox x:Name="ApiKeyBox" Width="330" VerticalContentAlignment="Center"/>
            <Button x:Name="SaveKeyButton" Content="Enregistrer" Margin="8,0,0,0" Padding="10,4" Click="OnSaveKey"/>
        </StackPanel>

        <!-- Zone de chat -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="SelectRegionButton" Content="1. Sélectionner la zone de chat" Padding="10,6" Click="OnSelectRegion"/>
            <TextBlock x:Name="RegionLabel" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#FFB0B0C0"/>
        </StackPanel>

        <!-- Démarrage -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="StartStopButton" Content="2. Démarrer la traduction" Padding="10,6"
                    FontWeight="Bold" Click="OnStartStop"/>
            <Button x:Name="EditOverlayButton" Content="Déplacer l'overlay" Padding="10,6" Margin="10,0,0,0"
                    Click="OnToggleEditOverlay"/>
            <CheckBox x:Name="MirrorAllCheck" Content="Tout afficher (pings/système)" Foreground="White"
                      VerticalAlignment="Center" Margin="14,0,0,0"
                      ToolTip="Reflète toutes les lignes du chat : traduites si coréennes (client KR), copiées sinon. Décoché = chat joueur uniquement (recommandé en live)."
                      Checked="OnMirrorAllChanged" Unchecked="OnMirrorAllChanged"/>
        </StackPanel>

        <!-- Test bout-en-bout sans partie en cours -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Test sans jeu :" VerticalAlignment="Center" Width="130"
                       ToolTip="Envoie ce message coréen dans la vraie chaîne de traduction (glossaire → cache → LLM/proxy → local) et affiche le résultat dans l'overlay. Valide la configuration sans lancer de partie."/>
            <TextBox x:Name="TestInputBox" Width="330" VerticalContentAlignment="Center" Text="미드 갱 좀 와주세요 ㅈㄴ 힘들어"/>
            <Button Content="Tester la traduction" Margin="8,0,0,0" Padding="10,4" Click="OnTestTranslate"/>
        </StackPanel>

        <!-- Statut -->
        <TextBlock x:Name="StatusLabel" Grid.Row="5" Margin="0,0,0,8" Foreground="#FF8BE28B"
                   TextWrapping="Wrap" Text="Prêt."/>

        <!-- Diagnostic -->
        <GroupBox Grid.Row="6" Header="Diagnostic (OCR brut → messages traduits)" Foreground="White">
            <ListBox x:Name="DiagnosticList" Background="#FF14141A" Foreground="#FFD0D0DC"
                     FontFamily="Consolas" FontSize="12"/>
        </GroupBox>

        <TextBlock Grid.Row="7" Margin="0,8,0,0" FontSize="11" Foreground="#FF9090A0" TextWrapping="Wrap"
                   Text="LoL en mode « Sans bordure ». App 100 % externe au jeu : capture d'écran + overlay, aucune interaction avec le process (compatible Vanguard). KRTradToFRLoL isn't endorsed by Riot Games."/>
    </Grid>
</Window>
