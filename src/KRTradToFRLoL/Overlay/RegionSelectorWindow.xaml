<Window x:Class="KRTradToFRLoL.Overlay.RegionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sélection de la zone de chat"
        WindowStyle="None" AllowsTransparency="True" Background="#50000000"
        Topmost="True" ShowInTaskbar="False" WindowState="Maximized"
        Cursor="Cross" KeyDown="OnKeyDown"
        MouseLeftButtonDown="OnMouseDown" MouseMove="OnMouseMove" MouseLeftButtonUp="OnMouseUp">
    <Canvas x:Name="RootCanvas">
        <TextBlock Canvas.Left="40" Canvas.Top="30" FontSize="20" Foreground="White"
                   Text="Dessine un rectangle autour de la ZONE DE CHAT du jeu (Échap pour annuler)"/>
        <Rectangle x:Name="SelectionRect" Stroke="#FF2EA8FF" StrokeThickness="2" Fill="#302EA8FF"
                   Visibility="Collapsed"/>
    </Canvas>
</Window>
